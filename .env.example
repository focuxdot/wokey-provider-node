# Wokey Provider Node — example environment file
#
# Copy to `.env.local` and adjust as needed. `npm start` loads `.env.local`
# automatically (via --env-file-if-exists). Every value below is optional;
# the listed default is what Provider Node uses when the variable is unset.
#
# Never commit a real `.env.local`. Only this `.env.example` is tracked.

# --- Local console ----------------------------------------------------------

# Interface the local console binds to. Keep it on loopback. Binding to
# 0.0.0.0 / :: is rejected by the console's loopback guard.
# PROVIDER_CONSOLE_HOST=127.0.0.1

# Local console port.
# PROVIDER_CONSOLE_PORT=16888

# Extra Host header values accepted by the console, comma-separated. Only needed
# if you front the console with a custom local hostname. 127.0.0.1, localhost,
# and ::1 are always allowed.
# PROVIDER_CONSOLE_ALLOWED_HOSTS=

# Base URL the `wokey-node` CLI uses to reach the local console. Defaults to
# http://<PROVIDER_CONSOLE_HOST>:<PROVIDER_CONSOLE_PORT>.
# PROVIDER_NODE_CLI_BASE_URL=http://127.0.0.1:16888

# --- Storage & secrets ------------------------------------------------------

# Path to the node config file. Secrets inside it are encrypted at rest.
# PROVIDER_CONFIG_PATH=./data/provider-node.json

# Master key for at-rest encryption of config secrets (node secret, API keys,
# OAuth tokens).
# If unset, Provider Node generates a random key in `<config>.key` (mode 0600)
# next to the config file. Set this to manage the key yourself (e.g. from a
# secrets manager) and keep it out of the config directory. The value is run
# through scrypt, but you should still supply high-entropy material — ideally 32
# random bytes, e.g. `openssl rand -hex 32` — not a short human-chosen password.
# PROVIDER_NODE_MASTER_KEY=

# --- Platform connection ----------------------------------------------------

# Additional Platform hosts (comma-separated) the node may be repointed to,
# beyond the built-in trusted domains and loopback. Use this only for a custom
# Platform host you control.
# PROVIDER_PLATFORM_HOST_ALLOWLIST=

# Egress allowlist for the official-exit tunnel: the only hosts this machine may
# open an outbound TCP connection to on Platform's instruction. Comma-separated.
# An entry starting with "." or "*." matches the domain and its subdomains; any
# other entry matches the host exactly.
#
# Default (unset/empty) = official vendor hosts only:
# - OpenAI / Codex: api.openai.com, chatgpt.com
# - Anthropic / Claude: api.anthropic.com
# - Qwen: dashscope.aliyuncs.com, dashscope-us.aliyuncs.com
# - Zhipu AI: open.bigmodel.cn, api.z.ai
# - Moonshot / Kimi: api.kimi.com, api.moonshot.ai, api.moonshot.cn
# - MiniMax: api.minimax.io, api.minimaxi.com
# - Xiaomi MiMo: api.xiaomimimo.com
# - DeepSeek: api.deepseek.com
# - Google Gemini: generativelanguage.googleapis.com
# - xAI: api.x.ai
#
# This setting is read only from this local environment; Platform cannot widen or
# disable it. Wildcard "*" is not supported; use explicit hosts or domain patterns.
# PROVIDER_OFFICIAL_EXIT_ALLOWED_HOSTS=api.openai.com,chatgpt.com,api.anthropic.com,dashscope.aliyuncs.com,dashscope-us.aliyuncs.com,open.bigmodel.cn,api.z.ai,api.kimi.com,api.moonshot.ai,api.moonshot.cn,api.minimax.io,api.minimaxi.com,api.xiaomimimo.com,api.deepseek.com,generativelanguage.googleapis.com,api.x.ai
# Binary-v1 transport is selected by Platform only for its canary cohort.
# These local bounds apply after negotiation.
PROVIDER_OFFICIAL_EXIT_BACKPRESSURE_TIMEOUT_MS=30000
PROVIDER_WS_BACKPRESSURE_HIGH_WATER_BYTES=4194304

# --- Misc -------------------------------------------------------------------

# Log level: trace | debug | info | warn | error
# LOG_LEVEL=info

# Console / CLI language override (e.g. en, zh). Auto-detected by default.
# WOKEY_LANG=
